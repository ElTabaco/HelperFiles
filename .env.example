# HelperFiles secrets — copy to .env and fill in real values
# .env is gitignored and will never be committed

# k3s cluster token (used by install.sh and installcredentials.sh)
# To rotate: sudo /usr/local/bin/k3s-secret-rotate on mr0
K3S_SECRET=mr_cluster_infra_20

# Server IP or hostname
K3S_SERVER=192.168.0.200